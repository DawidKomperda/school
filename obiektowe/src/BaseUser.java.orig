import java.util.Scanner;

public abstract class BaseUser {
    private static int idCounter = 1;

    private int id;
    private int shopId;
    private String username;
    private String password;
    private boolean loggedIn;
    private boolean cashRegister;

    // Default constructor for tests
    public BaseUser() {
        this.id = idCounter++;
    }

    public BaseUser(String username, String password, int shopId) {
        this.id = idCounter++;
        this.username = username;
        this.password = password;
        this.shopId = shopId;
        this.loggedIn = false;
        this.cashRegister = false;
    }

    public int getId() { return id; }
    public String getUsername() { return username; }
    public void setUsername(String username) { this.username = username; }
    public String getPassword() { return password; }
    public void setPassword(String password) { this.password = password; }
    public int getShopId() { return shopId; }
    public void setShopId(int shopId) { this.shopId = shopId; }

    public boolean isLoggedIn() { return loggedIn; }
    public void login() { this.loggedIn = true; }
    public void logout() { this.loggedIn = false; }

    public boolean isCashRegister() { return cashRegister; }
    public void openCashRegister() { this.cashRegister = true; }
    public void closeCashRegister() { this.cashRegister = false; }

    public abstract String getRoleName();
    public abstract boolean canApproveOrders();
    public abstract boolean canEditStorage();
    public abstract void delivery();
    protected abstract int getSecurityClearance();

    public abstract BaseUser createAdmin();
    public abstract BaseUser createManager();
    public abstract BaseUser createEmployee();

    protected boolean canDeleteUser(BaseUser userToDelete) {
        return this.getSecurityClearance() >= 50 && this.getSecurityClearance() >= userToDelete.getSecurityClearance();
    }

    public boolean deleteUser(BaseUser userToDelete) {
        if (canDeleteUser(userToDelete)) {
            System.out.println("User " + userToDelete.getUsername() + " successfully deleted by " + this.getUsername() + " (" + this.getRoleName() + ")");
            return true;
        } else {
            System.out.println(this.getRoleName() + " does not have permission to delete " + userToDelete.getRoleName());
            throw new SecurityException("Permission denied to delete user.");
        }
    }

    public void displayStock(Storage storage) {
        System.out.println("--- Products in Storage ---");
        for (int i = 1; i <= storage.getNumber(); i++) {
            Items item = storage.findItemById(i);
            if (item != null) {
                System.out.println(i + ". " + item.getProductName() + " | Amount: " + item.getNumber());
            }
        }
        System.out.println("---------------------------");
    }

    public void itemSell(int itemId, int quantity, Storage storage) {
        if (!cashRegister) {
            System.out.println("Open the cash register first.");
            return;
        }
        Items item = storage.findItemById(itemId);
        if (item != null) {
            if (item.getNumber() >= quantity) {
                storage.decreaseStockById(itemId, quantity);
                System.out.println("Sold " + quantity + "x " + item.getProductName());
            } else {
                System.out.println("Not enough items in stock to sell.");
            }
        } else {
            System.out.println("Item ID " + itemId + " not found.");
        }
    }

    public void itemReturn(int itemId, int quantity, Storage storage) {
        Items item = storage.findItemById(itemId);
        if (item != null) {
            storage.increaseStockById(itemId, quantity);
            System.out.println("Returned " + quantity + "x " + item.getProductName() + " to storage!");
        } else {
            System.out.println("Item ID " + itemId + " not found in storage.");
        }
    }

    public void manageWares(Storage storage) {
        if (!canEditStorage()) {
            throw new SecurityException("You do not have permission to manage wares.");
        }
        Scanner in = new Scanner(System.in);
        System.out.println("Item to rename ID: ");
        int itemId = in.nextInt();
        in.nextLine();
        System.out.println("New Name: ");
        String name = in.nextLine();
        System.out.println("New Stock Amount: ");
        int amount = in.nextInt();
        editStorageDetail(storage, itemId, name, amount);
    }

    public void editStorageDetail(Storage storage, int itemId, String newName, int newAmount) {
        if (!canEditStorage()) {
            throw new SecurityException("You do not have permission to edit storage details.");
        }
        Items item = storage.findItemById(itemId);
        if (item != null) {
            item.setProductName(newName);
            item.setNumber(newAmount);
            System.out.println("Item ID: " + itemId + " successfully updated!");
        } else {
            System.out.println("Item not found. Could not edit.");
        }
    }
}
